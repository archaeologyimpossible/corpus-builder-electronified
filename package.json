{
  "name": "corpus-assembler",
  "version": "1.0.0",
  "description": "photo collection and annotation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "dependencies": {
    "express": "^4.22.1"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.shawngraham.corpus-assembler",
    "productName": "Photo Corpus Assembler",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "server.js",
      "dist/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
